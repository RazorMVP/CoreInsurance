{
  "openapi": "3.1.0",
  "info": {
    "title": "CIA Partner API",
    "description": "Open API for Insurtech connectivity — aggregators, digital brokers, and embedded insurance providers.",
    "version": "1.0.0",
    "contact": {
      "name": "CIA Partner Support",
      "email": "partners@cia.app"
    }
  },
  "servers": [
    { "url": "{{baseUrl}}/partner/v1", "description": "Partner API base" }
  ],
  "security": [
    { "bearerAuth": [] }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "ApiResponse": {
        "type": "object",
        "properties": {
          "data": {},
          "meta": { "type": "object" },
          "errors": { "type": "array", "items": { "type": "object" } }
        }
      }
    }
  },
  "paths": {
    "/products": {
      "get": {
        "summary": "List products",
        "operationId": "listProducts",
        "tags": ["Products"],
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "List of active products" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/products/{id}": {
      "get": {
        "summary": "Get product",
        "operationId": "getProduct",
        "tags": ["Products"],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }],
        "responses": {
          "200": { "description": "Product details" },
          "404": { "description": "Not found" }
        }
      }
    },
    "/products/{id}/classes": {
      "get": {
        "summary": "List classes of business for a product",
        "operationId": "listProductClasses",
        "tags": ["Products"],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }],
        "responses": {
          "200": { "description": "Classes of business" }
        }
      }
    },
    "/quotes": {
      "post": {
        "summary": "Create quote",
        "operationId": "createQuote",
        "tags": ["Quotation"],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "type": "object" } } }
        },
        "responses": {
          "201": { "description": "Quote created" },
          "400": { "description": "Validation error" }
        }
      }
    },
    "/quotes/{id}": {
      "get": {
        "summary": "Get quote",
        "operationId": "getQuote",
        "tags": ["Quotation"],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }],
        "responses": {
          "200": { "description": "Quote details" },
          "404": { "description": "Not found" }
        }
      }
    },
    "/customers/individual": {
      "post": {
        "summary": "Register individual customer",
        "operationId": "registerIndividualCustomer",
        "tags": ["Customers"],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "type": "object" } } }
        },
        "responses": {
          "201": { "description": "Customer registered" }
        }
      }
    },
    "/customers/corporate": {
      "post": {
        "summary": "Register corporate customer",
        "operationId": "registerCorporateCustomer",
        "tags": ["Customers"],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "type": "object" } } }
        },
        "responses": {
          "201": { "description": "Customer registered" }
        }
      }
    },
    "/customers/{id}": {
      "get": {
        "summary": "Get customer",
        "operationId": "getCustomer",
        "tags": ["Customers"],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }],
        "responses": {
          "200": { "description": "Customer details" },
          "404": { "description": "Not found" }
        }
      }
    },
    "/policies": {
      "post": {
        "summary": "Bind policy",
        "operationId": "bindPolicy",
        "tags": ["Policies"],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "type": "object" } } }
        },
        "responses": {
          "201": { "description": "Policy bound" }
        }
      }
    },
    "/policies/{id}": {
      "get": {
        "summary": "Get policy",
        "operationId": "getPolicy",
        "tags": ["Policies"],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }],
        "responses": {
          "200": { "description": "Policy details" },
          "404": { "description": "Not found" }
        }
      }
    },
    "/policies/{id}/document": {
      "get": {
        "summary": "Download policy certificate (PDF)",
        "operationId": "downloadPolicyDocument",
        "tags": ["Policies"],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }],
        "responses": {
          "200": {
            "description": "PDF document",
            "content": { "application/pdf": { "schema": { "type": "string", "format": "binary" } } }
          }
        }
      }
    },
    "/policies/{id}/claims": {
      "post": {
        "summary": "Submit claim notification",
        "operationId": "submitClaim",
        "tags": ["Claims"],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "type": "object" } } }
        },
        "responses": {
          "201": { "description": "Claim registered" }
        }
      }
    },
    "/claims/{id}": {
      "get": {
        "summary": "Get claim status",
        "operationId": "getClaim",
        "tags": ["Claims"],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }],
        "responses": {
          "200": { "description": "Claim details" },
          "404": { "description": "Not found" }
        }
      }
    },
    "/webhooks": {
      "post": {
        "summary": "Register webhook",
        "operationId": "registerWebhook",
        "tags": ["Webhooks"],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "type": "object" } } }
        },
        "responses": {
          "201": { "description": "Webhook registered" }
        }
      },
      "get": {
        "summary": "List webhooks",
        "operationId": "listWebhooks",
        "tags": ["Webhooks"],
        "responses": {
          "200": { "description": "Registered webhooks" }
        }
      }
    },
    "/webhooks/{id}": {
      "delete": {
        "summary": "Delete webhook",
        "operationId": "deleteWebhook",
        "tags": ["Webhooks"],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }],
        "responses": {
          "204": { "description": "Deleted" }
        }
      }
    }
  }
}
